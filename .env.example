# SEO Tools Platform - Environment Variables

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
REDIS_RETRY_COOLDOWN_SEC=30

# Server Configuration
PORT=8000
HOST=0.0.0.0
DEBUG=false

# Application Settings
MAX_PAGES_DEFAULT=100
MAX_PAGES_LIMIT=2000
MAX_CONCURRENT_TASKS=10
RATE_LIMIT_PER_HOUR=999
RATE_LIMIT_WINDOW=10
HISTORY_SIZE=10

# Playwright
PLAYWRIGHT_BROWSERS_PATH=0

# Bot checker
BOT_CHECK_ENGINE=legacy
BOT_CHECK_TIMEOUT=15
BOT_CHECK_MAX_WORKERS=10

# Mobile checker
MOBILE_CHECK_ENGINE=v2
MOBILE_CHECK_TIMEOUT=35
MOBILE_CHECK_MODE=quick

# Render audit
RENDER_AUDIT_ENGINE=v2
RENDER_AUDIT_TIMEOUT=35

# Site Audit Pro rollout
SITE_AUDIT_PRO_ENABLED=true
SITE_AUDIT_PRO_DEFAULT_MODE=quick
SITE_AUDIT_PRO_MAX_PAGES_LIMIT=5

# Clusterizer
CLUSTERIZER_MAX_KEYWORDS=2000

# Memory guard / fallback stores
MEMORY_SWEEP_INTERVAL_SEC=60
MEMORY_IDLE_CLEANUP_SEC=300
MEMORY_GC_COOLDOWN_SEC=120
TASK_STORE_MEMORY_TTL_SEC=7200
TASK_STORE_MEMORY_MAX_ITEMS=200
TASK_STORE_IDLE_KEEP_SEC=900
PROGRESS_MEMORY_TTL_SEC=7200
PROGRESS_MEMORY_MAX_ITEMS=2000
PROGRESS_IDLE_KEEP_SEC=900

# Core Web Vitals (Google PageSpeed Insights)
# Get your key at: https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=YOUR_GOOGLE_PSI_API_KEY_HERE

# CORS allowed origins (comma-separated list of allowed frontend origins).
# Leave empty to allow all (*). For production, set to your exact domain(s).
# Example: ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=

# Python
PYTHONUNBUFFERED=1
